{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-ninja",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/presets/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "ninja-debug",
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "ninja-release",
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "ninja-strict",
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "vs2022-debug",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/presets/${presetName}",
      "cacheVariables": {
        "ENABLE_WARNINGS_AS_ERRORS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-ninja-debug",
      "configurePreset": "ninja-debug"
    },
    {
      "name": "build-ninja-release",
      "configurePreset": "ninja-release"
    },
    {
      "name": "build-ninja-strict",
      "configurePreset": "ninja-strict"
    },
    {
      "name": "build-vs2022-debug",
      "configurePreset": "vs2022-debug",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "test-ninja-debug",
      "configurePreset": "ninja-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-ninja-strict",
      "configurePreset": "ninja-strict",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-vs2022-debug",
      "configurePreset": "vs2022-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}